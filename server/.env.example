# 服务器配置
PORT=3000
NODE_ENV=development

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=memory_collector

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT密钥
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# 日志级别
LOG_LEVEL=info

# 微信小游戏配置
WECHAT_APPID=your_appid
WECHAT_SECRET=your_secret