# 环境变量配置
NODE_ENV=development
PORT=3000

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=memory_collector
DB_USER=game_user
DB_PASSWORD=game_pass_123

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT配置
JWT_SECRET=your_secret_key_here
JWT_EXPIRES_IN=7d

# 日志配置
LOG_LEVEL=debug

# 微信支付配置（生产环境）
WECHAT_APPID=
WECHAT_MCHID=
WECHAT_API_KEY=
WECHAT_NOTIFY_URL=https://your-domain.com/api/payment/wechat-notify

# 阿里云OSS配置（可选）
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_REGION=
